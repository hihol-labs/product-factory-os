{
  "version": 1,
  "purpose": "Machine-readable permission matrix for Product Factory OS agents.",
  "defaultDecision": "deny",
  "actors": {
    "codex": {
      "description": "Default coding agent session"
    },
    "user": {
      "description": "Project owner or explicit human approver"
    }
  },
  "capabilities": {
    "read": {
      "default": "allow",
      "approvalRequired": false,
      "evidence": ["referenced_files"]
    },
    "write": {
      "default": "scoped",
      "approvalRequired": "outside_allowed_write_areas",
      "scopeSource": [".pfo/UNIT_CONTEXT_MANIFEST.json", ".pfo/EXECUTION_POLICY.json"],
      "evidence": ["diff", "manifest"]
    },
    "test": {
      "default": "allow_when_declared",
      "approvalRequired": false,
      "scopeSource": [".pfo/VERIFICATION_CONTRACT.json", "TEST_PLAN.md"],
      "evidence": [".codex-memory/events.jsonl", "verificationHistory"]
    },
    "commit": {
      "default": "scoped",
      "approvalRequired": "when_not_requested",
      "evidence": ["commit_hash", ".codex-memory/events.jsonl"]
    },
    "push": {
      "default": "block",
      "approvalRequired": true,
      "evidence": ["remote_branch", ".codex-memory/events.jsonl"]
    },
    "deploy": {
      "default": "block",
      "approvalRequired": true,
      "requires": ["verification_contract_passed", "rollback_or_recovery_defined"],
      "evidence": ["approval", "rollback", "gate_results", ".codex-memory/events.jsonl"]
    },
    "external_api": {
      "default": "scoped",
      "approvalRequired": "write_or_sensitive_read",
      "scopeSource": [".pfo/TOOL_CAPABILITY_REGISTRY.json"],
      "evidence": ["tool_event", ".codex-memory/events.jsonl"]
    },
    "secrets": {
      "default": "block",
      "approvalRequired": true,
      "evidence": ["approval", "reason", ".codex-memory/events.jsonl"]
    },
    "context_budget": {
      "default": "allow_when_declared",
      "approvalRequired": false,
      "scopeSource": [".pfo/PERMISSION_MATRIX.json", ".pfo/EXECUTION_POLICY.json"],
      "evidence": [".codex-memory/events.jsonl", ".codex-memory/context-index.json", ".codex-memory/resume-snapshot.md"]
    }
  },
  "contextRuntimePolicy": {
    "version": 1,
    "mode": "budgeted-summary",
    "limits": {
      "toolOutputWarnBytes": 12000,
      "toolOutputBlockBytes": 48000,
      "toolOutputWarnLines": 240,
      "toolOutputBlockLines": 960,
      "readOutputWarnBytes": 16000,
      "readOutputBlockBytes": 64000,
      "readOutputWarnLines": 300,
      "readOutputBlockLines": 1200,
      "logOutputWarnBytes": 24000,
      "logOutputBlockBytes": 96000,
      "logOutputWarnLines": 500,
      "logOutputBlockLines": 2000,
      "webOutputWarnBytes": 12000,
      "webOutputBlockBytes": 40000,
      "webOutputWarnLines": 200,
      "webOutputBlockLines": 800,
      "httpOutputWarnBytes": 8000,
      "httpOutputBlockBytes": 24000,
      "httpOutputWarnLines": 160,
      "httpOutputBlockLines": 600
    },
    "routing": {
      "rawHttp": "block-unless-approved-or-summarized",
      "largeOutputWorkflow": "sandbox-summary",
      "summaryRequired": true,
      "summaryArtifact": ".codex-memory/context-summary.md"
    },
    "index": {
      "path": ".codex-memory/context-index.json",
      "source": ".codex-memory/events.jsonl"
    },
    "snapshot": {
      "path": ".codex-memory/resume-snapshot.md",
      "maxItems": 8
    },
    "evidence": [
      ".codex-memory/events.jsonl",
      ".codex-memory/context-index.json",
      ".codex-memory/resume-snapshot.md"
    ]
  },
  "costRiskPolicy": {
    "version": 1,
    "mode": "risk-and-budget-routing",
    "riskScore": {
      "askThreshold": 50,
      "denyThreshold": 90
    },
    "estimatedCostUsd": {
      "askThreshold": 3.0,
      "denyThreshold": 10.0
    },
    "modelTiers": {
      "cheap": "Use for trivial or low-risk work.",
      "standard": "Use for normal scoped implementation and review.",
      "strong": "Use for high-risk architecture, security, migration, deploy, or final review."
    },
    "evidence": [
      ".codex-memory/events.jsonl",
      "costRiskRouting",
      "policyRuntime"
    ]
  },
  "rules": [
    "A blocked capability requires explicit user approval before action.",
    "A scoped capability must stay inside its declared scope source.",
    "Every approval, denial, command, gate, external tool call, and secret access attempt must be logged to .codex-memory/events.jsonl.",
    "Large tool, read, log, web, and raw HTTP outputs must pass context_budget or be routed through sandbox-summary before entering active chat context.",
    "Production deploy, migration, DNS, billing, external writes, and secret reads are never implicit.",
    "Cost and risk routing must choose the cheapest sufficient model tier before expensive execution."
  ]
}
