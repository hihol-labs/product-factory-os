  "confidenceRules": {
    "high": "One product type has multiple direct signals and no conflicting product-type signals.",
    "medium": "One product type is likely, but domain or infrastructure is ambiguous.",
    "low": "Multiple product types are plausible or the idea lacks enough detail."
  },
  "ambiguityRules": {
    "askClarifyingQuestion": "Ask only when ambiguity changes architecture, security, data model, or deployment.",
    "defaultWhenDelegated": "If the user says to decide, choose the simplest reversible architecture and record the assumption."
  },
  "complexityRules": {
    "small": "Single actor, few flows, local/static deployment, no sensitive multi-user data.",
    "medium": "Multiple modules, persistent data, auth, external integrations, or scheduled work.",
