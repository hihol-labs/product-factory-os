{
  "version": 1,
  "defaultProfile": "standard",
  "profiles": {
    "minimal": {
      "label": "Minimal route profile",
      "intendedFor": "Small existing-project tasks with no behavior, data, deploy, security, migration, or broad architecture change.",
      "selectionHints": [
        "small task",
        "tiny change",
        "typo",
        "copy edit",
        "readme",
        "docs-only",
        "no behavior change",
        "/doc",
        "/explain",
        "/review"
      ],
      "steps": [
        "adoption",
        "scope",
        "targetedVerification",
        "review",
        "stateSave"
      ],
      "gates": [
        "adoption",
        "scopeLock",
        "targetedVerification",
        "specComplianceReview",
        "codeQualityReview"
      ],
      "requiredArtifacts": [
        "AGENTS.md",
        "CODEX.md",
        ".codex-memory/STATE.json",
        ".pfo/PROJECT_CONTRACT.md",
        ".pfo/SCOPE_LOCK.md",
        ".pfo/VERIFICATION_CONTRACT.json",
        ".pfo/UNIT_CONTEXT_MANIFEST.json"
      ],
      "optionalArtifacts": [
        "HANDOFF.md when switching sessions, roles, delegated agents, AFK execution, compaction, or recovery",
        "PFO_REPORT.md when adoption or analysis ran"
      ],
      "forbiddenArtifacts": [
        "PRODUCT_BLUEPRINT.md",
        "BUILD_PLAN.md",
        "EXECUTION_GRAPH.md",
        "TEST_PLAN.md",
        "QUALITY_GATES.md",
        "SECURITY_AUDIT_REPORT.md",
        "THREAT_MODEL.md"
      ],
      "verificationPolicy": {
        "mode": "targeted-only",
        "defaultCommands": [
          "python3 scripts/pfo_contract_gate.py <project>"
        ],
        "rules": [
          "Run only the contract/scope check and the narrow command that proves the touched files.",
          "Do not require planning artifacts, full fixture suite, production readiness, security, deps, deploy, or benchmark gates unless risk changes."
        ]
      }
    },
    "standard": {
      "label": "Standard route profile",
      "intendedFor": "Default non-trivial existing-project implementation, bugfix, refactor, test, or documentation work.",
      "selectionHints": [
        "/task",
        "/bugfix",
        "/test",
        "/refactor",
        "non-trivial existing-code work"
      ],
      "steps": [
        "adoption",
        "repositoryAnalysis",
        "taskClassification",
        "unitManifest",
        "targetedVerification",
        "review",
        "stateSave"
      ],
      "gates": [
        "adoption",
        "scopeLock",
        "verificationContract",
        "targetedVerification",
        "specComplianceReview",
        "codeQualityReview",
        "contextBudget",
        "toolCapabilityRegistry"
      ],
      "requiredArtifacts": [
        "AGENTS.md",
        "CODEX.md",
        ".codex-memory/STATE.json",
        ".pfo/PROJECT_CONTRACT.md",
        ".pfo/SCOPE_LOCK.md",
        ".pfo/EXECUTION_POLICY.json",
        ".pfo/PERMISSION_MATRIX.json",
        ".pfo/TOOL_CAPABILITY_REGISTRY.json",
        ".pfo/UNIT_CONTEXT_MANIFEST.json",
        ".pfo/VERIFICATION_CONTRACT.json",
        "active PIV plan under plans/ before implementation",
        "active implementation report under reports/ before review",
        "NEXT_STEP.md with approved or changed user-facing next step"
      ],
      "optionalArtifacts": [
        "ROOT_CAUSE.md for bugfix units",
        "HANDOFF.md when switching sessions, roles, delegated agents, AFK execution, compaction, or recovery",
        "TEST_PLAN.md when behavior coverage changes"
      ],
      "forbiddenArtifacts": [],
      "verificationPolicy": {
        "mode": "targeted-plus-contracts",
        "defaultCommands": [
          "python3 scripts/pfo_contract_gate.py <project>",
          "python3 scripts/validate_context_runtime.py"
        ],
        "rules": [
          "Run route-relevant validators and targeted tests before review.",
          "Escalate to full only when product scope, release, security, migration, deploy, or broad workflow risk changes."
        ]
      }
    },
    "full": {
      "label": "Full route profile",
      "intendedFor": "New projects, broad product changes, release/deploy readiness, security-sensitive work, migrations, or high-risk methodology changes.",
      "selectionHints": [
        "/project",
        "/kickstart",
        "/blueprint",
        "/deploy",
        "/migrate",
        "/security-audit",
        "/harden",
        "full cycle",
        "production"
      ],
      "steps": [
        "adoption",
        "repositoryAnalysis",
        "taskClassification",
        "planning",
        "unitManifest",
        "implementation",
        "fullVerification",
        "review",
        "branchFinish",
        "stateSave"
      ],
      "gates": [
        "adoption",
        "scopeLock",
        "ideaGate",
        "marketValidation",
        "verificationContract",
        "targetedVerification",
        "tests",
        "securityEvidence",
        "dependencies",
        "hardening",
        "specComplianceReview",
        "codeQualityReview",
        "branchFinish",
        "contextBudget",
        "toolCapabilityRegistry"
      ],
      "requiredArtifacts": [
        "AGENTS.md",
        "CODEX.md",
        ".codex-memory/STATE.json",
        ".pfo/PROJECT_CONTRACT.md",
        ".pfo/SCOPE_LOCK.md",
        ".pfo/EXECUTION_POLICY.json",
        ".pfo/PERMISSION_MATRIX.json",
        ".pfo/TOOL_CAPABILITY_REGISTRY.json",
        ".pfo/UNIT_CONTEXT_MANIFEST.json",
        ".pfo/VERIFICATION_CONTRACT.json",
        "PRODUCT_BLUEPRINT.md",
        "PROJECT_ARCHITECTURE.md",
        "BUILD_PLAN.md",
        "EXECUTION_GRAPH.md",
        "TEST_PLAN.md",
        "QUALITY_GATES.md",
        "active PIV plan under plans/ before implementation",
        "active implementation report under reports/ before review",
        "NEXT_STEP.md with approved or changed user-facing next step"
      ],
      "optionalArtifacts": [
        "IDEA_SCORECARD.md when product scope expands",
        "VALIDATION_PLAN.md when market risk is in scope",
        "ROOT_CAUSE.md for bugfix units",
        "SECURITY_AUDIT_REPORT.md for security-sensitive work",
        "THREAT_MODEL.md for security-sensitive work",
        "HANDOFF.md when switching sessions, roles, delegated agents, AFK execution, compaction, or recovery",
        "BRANCH_FINISH.md when branch cleanup is in scope"
      ],
      "forbiddenArtifacts": [],
      "verificationPolicy": {
        "mode": "full-contract",
        "defaultCommands": [
          "python3 scripts/pfo_contract_gate.py <project>",
          "python3 scripts/validate_context_runtime.py",
          "python3 scripts/production_readiness.py"
        ],
        "rules": [
          "Run the full verification contract before completion.",
          "Include security, dependency, deploy, and release gates when their risk class is present."
        ]
      }
    }
  }
}
