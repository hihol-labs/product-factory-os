    "command_router": ["command_map", "permissions", "help", "unknown_command"],
    "routing": ["paths", "methods", "request_validation", "response_contract"],
    "controllers": ["input_mapping", "response_mapping", "errors"],
    "services": ["business_logic", "transactions", "domain_errors", "idempotency"],
    "middleware": ["auth", "logging", "rate_limit", "cors", "security_headers"],
    "db_layer": ["models", "repositories", "migrations", "rollback"],
    "fetch": ["client", "headers", "rate_limits", "retries", "timeout"],
    "parse": ["selectors", "normalization", "validation", "fixture_tests"],
    "storage": ["schema", "repositories", "backup_or_export", "retention"],
    "scheduler": ["jobs", "intervals", "failure_policy", "dry_run"],
    "queue": ["producer", "consumer", "dead_letter_policy", "retry_policy"]
