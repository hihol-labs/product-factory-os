{
  "version": 1,
  "initialState": "IDLE",
  "terminalStates": ["DEPLOYED", "SESSION_SAVED"],
  "states": [
    "IDLE",
    "EXISTING_PROJECT_DETECTED",
    "ADOPTION_REQUIRED",
    "ADOPTED",
    "EXISTING_PROJECT_ANALYZED",
    "TASK_CLASSIFIED",
    "INTENT_CAPTURED",
    "CLASSIFIED",
    "ARCH_SELECTED",
    "BLUEPRINT_READY",
    "PHASE_DISCUSSION",
    "PLAN_READY",
    "UNIT_CONTEXT_READY",
    "UNIT_DISPATCHED",
    "BUILDING",
    "TESTING",
    "VERIFYING_WORK",
    "REVIEWING",
    "SECURITY_REVIEW",
    "DEPENDENCY_REVIEW",
    "HARDENING",
    "RECOVERY_REQUIRED",
    "REPAIRING",
    "BLOCKED_BY_USER_DECISION",
    "ROLLBACK_READY",
    "READY_FOR_DEPLOY",
    "DEPLOY_BLOCKED",
    "DEPLOYED",
    "SESSION_SAVED"
  ],
  "transitions": [
    {"from": "IDLE", "to": "INTENT_CAPTURED", "requires": ["user_intent"]},
    {"from": "IDLE", "to": "EXISTING_PROJECT_DETECTED", "requires": ["existing_project_signal"]},
    {"from": "EXISTING_PROJECT_DETECTED", "to": "ADOPTION_REQUIRED", "requires": ["missing_codex_or_memory_or_state"]},
    {"from": "ADOPTION_REQUIRED", "to": "ADOPTED", "requires": ["CODEX.md", ".codex-memory/MEMORY.md", ".codex-memory/STATE.json"]},
    {"from": "EXISTING_PROJECT_DETECTED", "to": "EXISTING_PROJECT_ANALYZED", "requires": ["codex_memory_state_present", "repository_inspected"]},
    {"from": "ADOPTED", "to": "EXISTING_PROJECT_ANALYZED", "requires": ["repository_inspected"]},
    {"from": "EXISTING_PROJECT_ANALYZED", "to": "TASK_CLASSIFIED", "requires": ["task_route_selected"]},
    {"from": "TASK_CLASSIFIED", "to": "PLAN_READY", "requires": ["task_plan_or_execution_node_ready"]},
    {"from": "INTENT_CAPTURED", "to": "CLASSIFIED", "requires": ["product_classification"]},
    {"from": "CLASSIFIED", "to": "ARCH_SELECTED", "requires": ["architecture_selection"]},
    {"from": "ARCH_SELECTED", "to": "BLUEPRINT_READY", "requires": ["PRODUCT_BLUEPRINT.md"]},
    {"from": "BLUEPRINT_READY", "to": "PHASE_DISCUSSION", "requires": ["phase_questions_answered_or_defaults_accepted"]},
    {"from": "TASK_CLASSIFIED", "to": "PHASE_DISCUSSION", "requires": ["task_route_selected", "implementation_decisions_needed"]},
    {"from": "PHASE_DISCUSSION", "to": "PLAN_READY", "requires": ["PHASE_CONTEXT.md", "BUILD_PLAN.md", "EXECUTION_GRAPH.md"]},
    {"from": "BLUEPRINT_READY", "to": "PLAN_READY", "requires": ["BUILD_PLAN.md", "EXECUTION_GRAPH.md"]},
    {"from": "PLAN_READY", "to": "UNIT_CONTEXT_READY", "requires": [".pfo/UNIT_CONTEXT_MANIFEST.json"]},
    {"from": "UNIT_CONTEXT_READY", "to": "UNIT_DISPATCHED", "requires": ["read_required_inputs", "write_scope_declared"]},
    {"from": "UNIT_DISPATCHED", "to": "BUILDING", "requires": ["dispatch_recorded"]},
    {"from": "PLAN_READY", "to": "BUILDING", "requires": ["review_not_blocked", "user_approval_for_new_project"]},
    {"from": "BUILDING", "to": "TESTING", "requires": ["module_complete"]},
    {"from": "BUILDING", "to": "VERIFYING_WORK", "requires": ["unit_complete", "verification_commands_declared"]},
    {"from": "VERIFYING_WORK", "to": "TESTING", "requires": ["definitive_verification_evidence"]},
    {"from": "VERIFYING_WORK", "to": "RECOVERY_REQUIRED", "requires": ["verification_unclear_or_failed"]},
    {"from": "TESTING", "to": "REVIEWING", "requires": ["tests_run_or_gap_documented"]},
    {"from": "REVIEWING", "to": "BUILDING", "requires": ["next_module_exists", "review_not_blocked"]},
    {"from": "REVIEWING", "to": "SECURITY_REVIEW", "requires": ["all_modules_complete", "review_not_blocked"]},
    {"from": "SECURITY_REVIEW", "to": "DEPENDENCY_REVIEW", "requires": ["security_pass_or_accepted_risk"]},
    {"from": "DEPENDENCY_REVIEW", "to": "HARDENING", "requires": ["deps_pass_or_accepted_risk"]},
    {"from": "HARDENING", "to": "READY_FOR_DEPLOY", "requires": ["production_readiness_pass", "rollback_or_recovery_defined"]},
    {"from": "REVIEWING", "to": "DEPLOY_BLOCKED", "requires": ["quality_gate_failed"]},
    {"from": "SECURITY_REVIEW", "to": "DEPLOY_BLOCKED", "requires": ["critical_security_finding"]},
    {"from": "DEPENDENCY_REVIEW", "to": "DEPLOY_BLOCKED", "requires": ["critical_dependency_finding"]},
    {"from": "HARDENING", "to": "DEPLOY_BLOCKED", "requires": ["critical_production_gap"]},
    {"from": "RECOVERY_REQUIRED", "to": "REPAIRING", "requires": ["repair_plan_ready"]},
    {"from": "DEPLOY_BLOCKED", "to": "REPAIRING", "requires": ["repair_plan_ready"]},
    {"from": "REPAIRING", "to": "BUILDING", "requires": ["code_or_doc_repair_needed"]},
    {"from": "REPAIRING", "to": "REVIEWING", "requires": ["gate_recheck_needed"]},
    {"from": "READY_FOR_DEPLOY", "to": "BLOCKED_BY_USER_DECISION", "requires": ["deploy_confirmation_missing"]},
    {"from": "READY_FOR_DEPLOY", "to": "ROLLBACK_READY", "requires": ["rollback_plan_verified"]},
    {"from": "ROLLBACK_READY", "to": "DEPLOYED", "requires": ["explicit_user_deploy_confirmation", "deploy_success"]},
    {"from": "READY_FOR_DEPLOY", "to": "DEPLOYED", "requires": ["explicit_user_deploy_confirmation", "deploy_success"]},
    {"from": "READY_FOR_DEPLOY", "to": "SESSION_SAVED", "requires": ["deployment_deferred", "state_saved"]},
    {"from": "DEPLOYED", "to": "SESSION_SAVED", "requires": ["state_saved"]}
  ],
  "blockedTransitions": [
    "BUILDING without BLUEPRINT_READY",
    "READY_FOR_DEPLOY without quality_gates_pass",
    "DEPLOYED without explicit_user_deploy_confirmation",
    "DEPLOYED without rollback_or_recovery_defined for production targets"
  ]
}
